  "recent_migrations_beta1": {
    "tables_created": [
      {
        "name": "collaboration_spaces",
        "columns": {
          "id": "uuid pk",
          "created_by": "uuid not null",
          "title": "text not null",
          "description": "text",
          "visibility": "text default 'private'",
          "status": "text default 'active'",
          "tags": "text[] default {}",
          "image_url": "text",
          "created_at": "timestamptz default now()",
          "updated_at": "timestamptz default now()"
        },
        "rls": {
          "select": "public OR approved member of space",
          "insert": "created_by = auth.uid()",
          "update_delete": "owner/admin (approved)"
        },
        "triggers": ["update_updated_at_column()"],
        "auto_membership": "Owner membership auto-created via trigger"
      },
      {
        "name": "collaboration_memberships",
        "columns": {
          "id": "uuid pk",
          "space_id": "uuid not null",
          "user_id": "uuid not null",
