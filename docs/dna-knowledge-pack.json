        "constraints": ["unique (space_id, user_id)"],
        "indexes": ["space_id", "user_id"],
        "rls": {
          "select": "approved member of that space",
          "insert": "self-request OR owner/admin inserts",
          "update_delete": "self OR owner/admin"
