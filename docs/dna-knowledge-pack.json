          "created_by": "uuid not null",
          "created_at": "timestamptz default now()",
          "updated_at": "timestamptz default now()"
        },
        "indexes": ["space_id", "assignee_id"],
        "rls": {
          "select": "approved member of space",
          "insert": "member + created_by = auth.uid()",
          "update": "creator OR assignee OR owner/admin",
          "delete": "creator OR owner/admin"
        },
        "triggers": ["update_updated_at_column()"]
      },
      {
        "name": "milestones",
        "columns": {
          "id": "uuid pk",
          "space_id": "uuid not null",
          "title": "text not null",
          "description": "text",
          "due_date": "date",
          "status": "text default 'planned'",
          "created_by": "uuid not null",
          "created_at": "timestamptz default now()",
          "updated_at": "timestamptz default now()"
        },
        "indexes": ["space_id"],
        "rls": {
          "select": "approved member of space",
          "insert": "member + created_by = auth.uid()",
          "update_delete": "creator OR owner/admin"
        },
        "triggers": ["update_updated_at_column()"]
      },
      {
        "name": "opportunities",
        "columns": {
          "id": "uuid pk",
          "created_by": "uuid not null",
          "space_id": "uuid",
          "title": "text not null",
          "description": "text",
          "type": "text default 'general'",
          "status": "text default 'active'",
          "visibility": "text default 'public'",
          "tags": "text[] default {}",
          "location": "text",
          "link": "text",
          "image_url": "text",
          "created_at": "timestamptz default now()",
          "updated_at": "timestamptz default now()"
        },
        "indexes": ["created_by", "space_id"],
        "rls": {
          "select": "public+active OR approved member of linked space",
