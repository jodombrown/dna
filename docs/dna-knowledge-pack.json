          "update_delete": "creator OR space owner/admin"
        },
        "triggers": ["update_updated_at_column()"]
      },
      {
        "name": "user_contributions",
        "purpose": "Track user actions for impact scoring and badges",
        "columns": {
          "id": "uuid pk",
          "user_id": "uuid not null",
          "type": "text (post|initiative|event|opportunity|community|newsletter)",
          "target_id": "uuid",
          "target_title": "text",
          "metadata": "jsonb {}",
          "created_at": "timestamptz default now()"
        },
        "indexes": ["user_id"],
        "rls": {
          "select": "self or admin",
          "insert": "user_id = auth.uid()"
        }
      },
      {
        "name": "impact_badges",
        "columns": {
          "id": "uuid pk",
          "badge_key": "text unique",
          "name": "text not null",
          "description": "text",
          "icon": "text",
          "criteria": "jsonb {}",
          "active": "boolean default true",
          "created_at": "timestamptz default now()"
        },
        "rls": {
          "select": "public",
          "manage": "admins only (ALL)"
        }
      },
      {
        "name": "user_badges",
        "columns": {
          "id": "uuid pk",
          "user_id": "uuid not null",
          "badge_type": "text",
          "badge_name": "text",
          "description": "text",
          "icon": "text",
          "created_at": "timestamptz default now()"
        },
        "constraints": ["unique (user_id, badge_type)"],
        "rls": {
          "select": "self or admin",
          "insert": "system (broad check true)"
        }
      }
    ],
    "shared_triggers_used": ["public.update_updated_at_column()"],
    "notes": [
